# ==========================================
# Integrated Deployment Git Ignore
# ==========================================

# 1. 极其重要：忽略所有本地环境变量和秘钥
.env
.env.local
.env.*.local
*.env

# 2. 忽略部署过程中生成的日志和备份
logs/
*.log
backups/

# 3. 忽略临时文件与 OS 特有文件
.DS_Store
Thumbs.db
node_modules/
dist/
build/

# 4. 忽略 Python 与 Docker 缓存
__pycache__/
*.pyc
.docker/
