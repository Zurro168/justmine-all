# === 正矿供应链环境变量模板 ===
# 复制此文件为 .env.justmine 并填入真实值

# AI 模型
DEEPSEEK_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...

# 企微配置
WECHAT_CORP_ID=ww...
WECHAT_TOKEN=justmine_wecom_token
WECHAT_ENCODING_AES_KEY=...
WECOM_AGENT_ID=...        # 正矿智能中台 的 AgentId（用于异步推送回复）
WECOM_APP_SECRET=...      # 正矿智能中台 的 Secret
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# Notion
NOTION_API_KEY=ntn_...                  # Notion Integration Token
NOTION_ARCHIVE_DATABASE_ID=...          # 正矿文件归档 数据库 ID
NOTION_SCOUT_DATABASE_ID=...            # Scout行情归档 数据库 ID

# 系统
DASHBOARD_PASS=
JWT_SECRET=change-me-to-a-random-string
ALLOWED_ORIGINS=http://localhost,https://www.justmine.cn
